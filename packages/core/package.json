{
  "name": "@appframe/core",
  "version": "0.1.0",
  "description": "Core engine for appframe — config, templates, rendering",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist", "templates"],
  "keywords": ["app-store", "play-store", "screenshots", "device-frames", "promotional"],
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "dependencies": {
    "nunjucks": "^3.2.4",
    "playwright": "^1.58.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/nunjucks": "^3.2.6"
  }
}
