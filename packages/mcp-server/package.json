{
  "name": "@appframe/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for AI-driven appframe workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "appframe-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./preview-hooks": {
      "types": "./dist/preview-hooks.d.ts",
      "import": "./dist/preview-hooks.js"
    },
    "./autopilot": {
      "types": "./dist/autopilot.d.ts",
      "import": "./dist/autopilot.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@appframe/core": "workspace:*",
    "@appframe/store-upload": "workspace:*",
    "@appframe/web-preview": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "files": ["dist"],
  "keywords": ["mcp", "app-store", "screenshots", "ai-agent"],
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  }
}
