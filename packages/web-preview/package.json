{
  "name": "@appframe/web-preview",
  "version": "0.1.0",
  "description": "Local web UI for previewing and tweaking appframe screenshots",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@appframe/core": "workspace:*",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "files": ["dist", "public"],
  "keywords": ["app-store", "screenshots", "preview"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6"
  }
}
