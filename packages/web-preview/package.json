{
  "name": "@appframe/web-preview",
  "version": "0.1.0",
  "description": "Local web UI for previewing and tweaking appframe screenshots",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "appframe-preview": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "node ./dist/bin.js",
    "build": "tsc && vite build",
    "build:client": "vite build",
    "dev": "tsc --watch",
    "dev:client": "vite",
    "clean": "rm -rf dist client-dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@appframe/core": "workspace:*",
    "@tiptap/core": "^3.23.4",
    "@tiptap/extension-color": "^3.23.4",
    "@tiptap/extension-text-align": "^3.23.4",
    "@tiptap/extension-text-style": "^3.23.4",
    "@tiptap/extension-underline": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "lucide-static": "^1.14.0",
    "modern-screenshot": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "yaml": "^2.8.2",
    "zustand": "^4.5.5"
  },
  "files": [
    "dist",
    "public",
    "client-dist",
    "data"
  ],
  "keywords": [
    "app-store",
    "screenshots",
    "preview"
  ],
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.4.2"
  }
}
