{
  "name": "@appframe/web-preview",
  "version": "0.1.0",
  "description": "Local web UI for previewing and tweaking appframe screenshots",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:client": "vite build",
    "dev": "tsc --watch",
    "dev:client": "vite",
    "clean": "rm -rf dist client-dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "@appframe/core": "workspace:*",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "files": ["dist", "public", "client-dist"],
  "keywords": ["app-store", "screenshots", "preview"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.0.0"
  }
}
